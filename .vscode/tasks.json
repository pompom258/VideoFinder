{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "typescript",
            "tsconfig": "tsconfig.json",
            "problemMatcher": ["$tsc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "shell": {
                    "executable": "pwsh.exe",
                    "args": [
                        "-NoProfile", "-NoLogo", "-Command"
                    ]
                }
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "if (Test-Path ${workspaceFolder}/public) { Remove-Item ${workspaceFolder}/public -Recurse -Force }",
            "options": {
                "shell": {
                    "executable": "pwsh.exe",
                    "args": [
                        "-NoProfile", "-NoLogo", "-Command"
                    ]
                }
            }
        }
    ]
}
